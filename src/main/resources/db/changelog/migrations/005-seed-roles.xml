<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-5.0.xsd">
    <changeSet id="seed-role-admin" author="edwin">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="user_roles"/>
                <sqlCheck expectedResult="0">
                    SELECT COUNT(*) FROM user_roles WHERE slug='admin'
                </sqlCheck>
            </and>
        </preConditions>
        <insert tableName="user_roles">
            <column name="name" value="admin"/>
            <column name="slug" value="admin"/>
        </insert>
    </changeSet>

    <changeSet id="seed-role-user" author="edwin">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="user_roles"/>
                <sqlCheck expectedResult="0">
                    SELECT COUNT(*) FROM user_roles WHERE slug='user'
                </sqlCheck>
            </and>
        </preConditions>
        <insert tableName="user_roles">
            <column name="name" value="user"/>
            <column name="slug" value="user"/>
        </insert>
    </changeSet>
</databaseChangeLog>