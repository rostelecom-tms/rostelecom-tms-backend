        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-5.0.xsd">

    <changeSet id="007-seed-cases" author="edwin">
        <!-- groups -->
        <insert tableName="case_groups">
            <column name="id" valueNumeric="100"/>
            <column name="name" value="Authentication"/>
            <column name="slug" value="authentication"/>
        </insert>

        <insert tableName="case_groups">
            <column name="id" valueNumeric="101"/>
            <column name="name" value="Profile"/>
            <column name="slug" value="profile"/>
        </insert>

        <insert tableName="case_groups">
            <column name="id" valueNumeric="102"/>
            <column name="name" value="Orders"/>
            <column name="slug" value="orders"/>
        </insert>

        <!-- cases -->
        <insert tableName="cases">
            <column name="id" valueNumeric="1000"/>
            <column name="title" value="Successful login with valid credentials"/>
            <column name="group_id" valueNumeric="100"/>
            <column name="description" value="User logs in with correct email and password."/>
            <column name="preconditions" value="User account exists and is active."/>
            <column name="postconditions" value="User is redirected to dashboard."/>
        </insert>

        <insert tableName="cases">
            <column name="id" valueNumeric="1001"/>
            <column name="title" value="Login fails with invalid password"/>
            <column name="group_id" valueNumeric="100"/>
            <column name="description" value="System shows error when password is incorrect."/>
            <column name="preconditions" value="User account exists."/>
            <column name="postconditions" value="User stays on login page."/>
        </insert>

        <insert tableName="cases">
            <column name="id" valueNumeric="1002"/>
            <column name="title" value="User can logout successfully"/>
            <column name="group_id" valueNumeric="100"/>
            <column name="description" value="Authenticated user logs out from the system."/>
            <column name="preconditions" value="User is logged in."/>
            <column name="postconditions" value="Session is terminated."/>
        </insert>

        <insert tableName="cases">
            <column name="id" valueNumeric="1003"/>
            <column name="title" value="User can view profile page"/>
            <column name="group_id" valueNumeric="101"/>
            <column name="description" value="Authenticated user opens profile page."/>
            <column name="preconditions" value="User is logged in."/>
            <column name="postconditions" value="Profile data is displayed."/>
        </insert>

        <insert tableName="cases">
            <column name="id" valueNumeric="1004"/>
            <column name="title" value="User can update profile name"/>
            <column name="group_id" valueNumeric="101"/>
            <column name="description" value="User changes profile name and saves changes."/>
            <column name="preconditions" value="User is logged in and profile page is accessible."/>
            <column name="postconditions" value="New name is saved and shown in UI."/>
        </insert>

        <insert tableName="cases">
            <column name="id" valueNumeric="1005"/>
            <column name="title" value="User cannot save empty profile name"/>
            <column name="group_id" valueNumeric="101"/>
            <column name="description" value="Validation prevents saving empty profile name."/>
            <column name="preconditions" value="User is logged in."/>
            <column name="postconditions" value="Validation error is shown."/>
        </insert>

        <insert tableName="cases">
            <column name="id" valueNumeric="1006"/>
            <column name="title" value="User can create a new order"/>
            <column name="group_id" valueNumeric="102"/>
            <column name="description" value="User creates a new order with valid data."/>
            <column name="preconditions" value="User is logged in and has at least one product available."/>
            <column name="postconditions" value="Order is created successfully."/>
        </insert>

        <insert tableName="cases">
            <column name="id" valueNumeric="1007"/>
            <column name="title" value="Order list displays created orders"/>
            <column name="group_id" valueNumeric="102"/>
            <column name="description" value="User sees previously created orders in the list."/>
            <column name="preconditions" value="There is at least one existing order."/>
            <column name="postconditions" value="Order list contains expected records."/>
        </insert>

        <insert tableName="cases">
            <column name="id" valueNumeric="1008"/>
            <column name="title" value="User can open order details page"/>
            <column name="group_id" valueNumeric="102"/>
            <column name="description" value="User opens detailed view of a selected order."/>
            <column name="preconditions" value="There is at least one existing order."/>
            <column name="postconditions" value="Order details are displayed."/>
        </insert>

        <insert tableName="cases">
            <column name="id" valueNumeric="1009"/>
            <column name="title" value="User can cancel draft order"/>
            <column name="group_id" valueNumeric="102"/>
            <column name="description" value="User cancels an order that is still in draft status."/>
            <column name="preconditions" value="Draft order exists."/>
            <column name="postconditions" value="Order status is changed to cancelled."/>
        </insert>

        <rollback>
            <delete tableName="cases">
                <where>id between 1000 and 1009</where>
            </delete>
            <delete tableName="case_groups">
                <where>id between 100 and 102</where>
            </delete>
        </rollback>
    </changeSet>

