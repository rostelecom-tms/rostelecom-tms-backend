    <changeSet id="003-seed-defects" author="edwin">
        <insert tableName="defects">
            <column name="id" valueNumeric="3000"/>
            <column name="case_id" valueNumeric="1001"/>
            <column name="title" value="Invalid credentials message is not localized"/>
            <column name="description" value="Error text is always shown in English."/>
            <column name="is_solved" valueBoolean="false"/>
        </insert>

        <insert tableName="defects">
            <column name="id" valueNumeric="3001"/>
            <column name="case_id" valueNumeric="1004"/>
            <column name="title" value="Updated profile name is not visible until page refresh"/>
            <column name="description" value="Backend saves changes, but UI is not refreshed automatically."/>
            <column name="is_solved" valueBoolean="false"/>
        </insert>

        <insert tableName="defects">
            <column name="id" valueNumeric="3002"/>
            <column name="case_id" valueNumeric="1009"/>
            <column name="title" value="Cancel order dialog can be closed without action"/>
            <column name="description" value="Dialog closes on outside click and user action is lost."/>
            <column name="is_solved" valueBoolean="true"/>
        </insert>

        <rollback>
            <delete tableName="defects">
                <where>id between 3000 and 3002</where>
            </delete>
        </rollback>
    </changeSet>

